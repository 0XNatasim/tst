# Supabase (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Supabase (production — mettre dans Vercel)
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@[REGION].pooler.supabase.co:6543/postgres

# Ingestion (crawlers) — données ouvertes du Québec via l'API CKAN.
# Par défaut, les ressources sont découvertes automatiquement à partir du
# « slug » du jeu de données sur donneesquebec.ca (datastore JSON si dispo,
# sinon téléchargement du CSV). Surcharge le slug si besoin :
# SEAO_DATASET=systeme-electronique-d-appel-d-offres-seao
# BUDGET_DATASET=budget-de-depenses
# CKAN_BASE=https://www.donneesquebec.ca/recherche/api/3/action
#
# Ou épingle directement un fichier CSV (court-circuite la découverte CKAN) :
# SEAO_CONTRACTS_URL=https://www.donneesquebec.ca/.../contrats.csv
# BUDGET_URL=https://www.donneesquebec.ca/.../depenses-par-portefeuille.csv

# Protège l'endpoint cron /api/cron/crawl (Vercel l'envoie en Bearer token).
# CRON_SECRET=change-me
