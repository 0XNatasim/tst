# Supabase (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Supabase (production — mettre dans Vercel)
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@[REGION].pooler.supabase.co:6543/postgres

# Ingestion (crawlers) — sources de données ouvertes du Québec.
# URLs des fichiers CSV à ingérer. Remplace par la ressource exacte de
# donneesquebec.ca (onglet "Données et ressources" du jeu de données).
# SEAO_CONTRACTS_URL=https://www.donneesquebec.ca/.../contrats.csv
# BUDGET_URL=https://www.donneesquebec.ca/.../depenses-par-portefeuille.csv

# Protège l'endpoint cron /api/cron/crawl (Vercel l'envoie en Bearer token).
# CRON_SECRET=change-me
